# Frontend environment variables (for Vercel)
# Copy this to .env.local for local dev, or paste into Vercel Dashboard -> Settings -> Environment Variables

# Your Render.com backend URL (set AFTER deploying backend)
# Example: https://sovereign-ai-backend.onrender.com
VITE_BACKEND_URL=https://YOUR-BACKEND-NAME.onrender.com

# Your Google OAuth Client ID from https://console.cloud.google.com/
# Steps to get it:
# 1. Go to https://console.cloud.google.com/
# 2. Create project "Sovereign AI"
# 3. APIs & Services -> Credentials -> Create Credentials -> OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorized JavaScript origins: Add your Vercel URL (e.g. https://sovereign-ai.vercel.app)
# 6. Authorized redirect URIs: Same Vercel URL
# 7. Copy the Client ID below
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
